[app]

# (str) اسم التطبيق الذي سيظهر على الشاشة
title = Alsayegh Pro

# (str) اسم الحزمة (يجب أن يكون فريداً وبدون مسافات)
package.name = alsayeghpro

# (str) النطاق البرمجي الخاص بك
package.domain = org.hozifa

# (str) مكان وجود ملف main.py
source.dir = .

# (list) الملفات التي سيتم تضمينها في التطبيق
source.include_exts = py,png,jpg,kv,atlas

# (str) رقم إصدار التطبيق (البداية القوية)
version = 1.0

# (list) المكتبات المطلوبة لتشغيل الكود الاحترافي
# أضفنا kivymd للتصميم الفخم و pillow لمعالجة الصور
requirements = python3,kivy==2.3.0,kivymd,pillow

# (str) وضعية الشاشة (طولية لتناسب الموبايل)
orientation = portrait

# (list) التصاريح (فتح الإنترنت لتحديث الأسعار مستقبلاً)
android.permissions = INTERNET

# (int) مستوى الأندرويد المستهدف (حديث جداً)
android.api = 33

# (int) أقل نظام أندرويد يعمل عليه التطبيق
android.minapi = 21

# (str) إصدار الأدوات البرمجية (NDK) المتوافق
android.ndk = 25b

# (str) بنية المعالج (arm64-v8a هو الأنسب لهواتف Honor الحديثة)
android.archs = arm64-v8a

# (bool) تفعيل النسخ الاحتياطي التلقائي
android.allow_backup = True

# (str) فرع أدوات بناء الأندرويد
p4a.branch = master

[buildozer]

# (int) مستوى تسجيل الأخطاء (2 يعني تفصيل كامل لنعرف لو حدث خطأ)
log_level = 2

# (int) التحذير عند التشغيل كمسؤول
warn_on_root = 1

